# Fixture Platform — environment template.
# Copy to backend/.env for local dev; set real values via your secret manager
# in production. NEVER commit a filled-in .env (it is gitignored).

# --- Core (required) ------------------------------------------------------
# Generate a strong 50+ char key, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
SECRET_KEY=replace-me-with-a-strong-50plus-char-random-value
DEBUG=True
# Comma-separated. Production MUST set your real hostnames.
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database -------------------------------------------------------------
# DEV: any local Postgres role is fine.
# PROD: use a NON-superuser, non-owner role so the append-only audit guarantee
#       (REVOKE UPDATE/DELETE on audit_event) cannot be bypassed by the app role.
DATABASE_URL=postgres://postgres:CHANGEME@localhost:5432/fixturedb

# --- Locale / TZ ----------------------------------------------------------
LANGUAGE_CODE=en-us
TIME_ZONE=Asia/Kolkata

# --- Super-admin bootstrap (one-time) -------------------------------------
# Used only by the bootstrap command to create the first super-admin.
# After bootstrap, ROTATE this password and remove these two lines.
SUPERUSER_EMAIL=you@example.com
SUPERUSER_PASSWORD=CHANGEME

# --- Super-admin console host / IP allowlist ------------------------------
SADMIN_HOST=localhost
# Comma-separated CIDR / IPs; empty = no restriction (set in prod).
SADMIN_IP_ALLOWLIST=

# --- Production-only (DJANGO_SETTINGS_MODULE=fixture.settings.prod) --------
# REDIS_URL=redis://127.0.0.1:6379/0
# CSRF_TRUSTED_ORIGINS=https://fixture.doxaed.com
# CORS_ALLOWED_ORIGINS=https://fixture.doxaed.com
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=no-reply@fixture.doxaed.com

# Error monitoring (optional; leave empty to disable)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
